  "roadmap": [
    {
      "id": "H-30",
      "priority": "HIGH",
      "state": "implementing",
      "expected": "−27..−31% vs zstd (probe-confirmed by H-29)",
      "refs": [
        "CLP (Uber)",
        "Parquet",
        "BtrBlocks"
      ],
      "title": {
        "en": "Columnar field-split",
        "ru": "Колоночный field-split"
      },
      "desc": {
        "en": "Reorder each field into its own column before BWT+geomix, so similar values sit together. The H-29 probe confirmed −27..−31% vs zstd on telemetry CSV — this is the round being built now.",
        "ru": "Переупорядочить каждое поле в отдельную колонку перед BWT+geomix, чтобы похожие значения лежали рядом. Проба H-29 подтвердила −27..−31% против zstd на телеметрии CSV — этот раунд сейчас в работе."
      }
    },
    {
      "id": "H-31",
      "priority": "HIGH",
      "state": "planned",
      "expected": "10–100× on timestamp columns (Parquet literature)",
      "refs": [
        "Parquet delta/FOR",
        "Denum"
      ],
      "title": {
        "en": "Timestamp / counter column delta",
        "ru": "Дельта по столбцам времени/счётчиков"
      },
      "desc": {
        "en": "After the split, store only the difference between consecutive values in monotonic columns (timestamps, ids). Fully reversible, no learning cost. Stacks on top of H-30.",
        "ru": "После разбиения хранить только разницу между соседними значениями в монотонных столбцах (метки времени, id). Полностью обратимо, без стоимости обучения. Стыкуется поверх H-30."
      }
    },
    {
      "id": "H-36",
      "priority": "HIGH",
      "state": "planned",
      "expected": "2.16–2.5× over zstd (CLP / LogPrism literature)",
      "refs": [
        "CLP",
        "Logzip",
        "LogPrism",
        "LogFold"
      ],
      "title": {
        "en": "Log template / variable split",
        "ru": "Разделение шаблон/переменные в логах"
      },
      "desc": {
        "en": "Parse each log line into a template id, a timestamp delta, and the variable values, then compress each stream separately. High ceiling but major complexity — gated by a mandatory Python spike first.",
        "ru": "Разобрать каждую строку лога на id шаблона, дельту времени и значения переменных, затем сжимать каждый поток отдельно. Высокий потолок, но крупная сложность — сперва обязательный Python-спайк как гейт."
      }
    },
    {
      "id": "H-32",
      "priority": "MEDIUM",
      "state": "planned",
      "expected": "+17–37% over LZMA as a preprocessor (LogLite literature)",
      "refs": [
        "LogLite (VLDB 2025)"
      ],
      "title": {
        "en": "XOR-cache line preprocessor",
        "ru": "XOR-кэш предобработчик строк"
      },
      "desc": {
        "en": "XOR each line against a recent same-length line and run-length the zero runs before BWT. Promising in the literature, but BWT+geomix may already capture this — competitive-gated.",
        "ru": "XOR каждой строки с недавней строкой той же длины и RLE нулевых серий перед BWT. В литературе перспективно, но BWT+geomix, возможно, уже это ловит — под competitive-гейтом."
      }
    },
    {
      "id": "H-35",
      "priority": "MEDIUM",
      "state": "planned",
      "expected": "3–4× over non-dict zstd for <1 KB records (narrow scope)",
      "refs": [
        "zstd --train",
        "Cassandra CEP-54"
      ],
      "title": {
        "en": "Trained dictionary for short records",
        "ru": "Обученный словарь для коротких записей"
      },
      "desc": {
        "en": "Train a small dictionary on the first records of a short-fixed-record block. Strong for sub-1 KB records (JSON API logs, Kafka, WAL); the effect vanishes on larger records. Narrow scope.",
        "ru": "Обучить небольшой словарь на первых записях блока коротких фиксированных записей. Сильно для записей <1 КБ (JSON API логи, Kafka, WAL); на больших записях эффект исчезает. Узкая область."
      }
    },
    {
      "id": "H-33",
      "priority": "MARGINAL",
      "state": "planned",
      "expected": "~1.6% on enwik9; maybe 2–3% on numeric-dense logs",
