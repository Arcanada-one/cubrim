# orchestrator.env.example — Template for orchestrator container env.
# Copy to orchestrator.env; no secret values needed here (auth via claude auth login).

CUBRIM_ROLE=orchestrator
CUBRIM_REPO_ROOT=/workspace/repo
CUBRIM_GATE_DIR=/workspace/gate
CUBRIM_STATE_DOC=CUBR-AUTONOMOUS-STATE.md
CUBRIM_RUN_LOG=datarim/cubrim-run-log.jsonl
CUBRIM_MIN_WORKERS=2
