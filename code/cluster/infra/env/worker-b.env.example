# worker-b.env.example — Template for Worker B (DeepSeek free tier).
# Copy to worker-b.env and fill in the real API key.
# This file is gitignored — never commit a real key.

CUBRIM_ROLE=worker-b

# claude-code-router routes Worker B to DeepSeek free tier
# Model: deepseek-coder (free plan; distinct weights from Worker A for voice independence)
ANTHROPIC_BASE_URL=https://api.deepseek.com/v1
ANTHROPIC_AUTH_TOKEN=<DEEPSEEK_API_KEY>
ANTHROPIC_MODEL=deepseek-coder

# Rate-limit back-off
CUBRIM_RATE_LIMIT_BACKOFF_SEC=300
