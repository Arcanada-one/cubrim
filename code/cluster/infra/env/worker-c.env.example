# worker-c.env.example — Template for Worker C (Groq llama, fast/high-TPM).
# Copy to worker-c.env and fill in the real API key.
# This file is gitignored — never commit a real key.

CUBRIM_ROLE=worker-c

# claude-code-router routes Worker C to Groq llama
# Used for: background tasks, probe-script drafting, summaries (fast + cheap).
ANTHROPIC_BASE_URL=https://api.groq.com/openai/v1
ANTHROPIC_AUTH_TOKEN=<GROQ_API_KEY>
ANTHROPIC_MODEL=llama-3.3-70b-versatile

# Groq is fast but has strict RPM caps — back off aggressively
CUBRIM_RATE_LIMIT_BACKOFF_SEC=120
