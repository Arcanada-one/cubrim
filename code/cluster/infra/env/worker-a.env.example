# worker-a.env.example — Template for Worker A (OpenRouter, qwen/qwen3-coder:free).
# Copy to worker-a.env and fill in the real API key.
# This file is gitignored — never commit a real key.

CUBRIM_ROLE=worker-a

# claude-code-router routes Worker A to OpenRouter qwen/qwen3-coder:free
ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_AUTH_TOKEN=<OPENROUTER_API_KEY>
ANTHROPIC_MODEL=qwen/qwen3-coder:free

# Rate-limit back-off when OpenRouter returns 429
CUBRIM_RATE_LIMIT_BACKOFF_SEC=300
